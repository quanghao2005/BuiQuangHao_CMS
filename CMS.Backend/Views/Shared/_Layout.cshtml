<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HaoCMS Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />

    <style>
        body {
            overflow-x: hidden;
            background-color: #f8f9fa;
        }
        /* Cấu trúc Sidebar cố định bên trái */
        .sidebar {
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            z-index: 100;
            width: 260px;
            background-color: #212529; /* Màu tối sang trọng */
            padding-top: 20px;
            box-shadow: 4px 0 10px rgba(0,0,0,0.1);
            transition: all 0.3s;
        }
            /* Định dạng các đường link trong menu */
            .sidebar .nav-link {
                color: #adbcbc;
                font-weight: 500;
                padding: 12px 20px;
                display: flex;
                align-items: center;
                gap: 12px;
                border-left: 4px solid transparent;
            }

                .sidebar .nav-link:hover, .sidebar .nav-link.active {
                    color: #ffffff;
                    background-color: #2c3034;
                    border-left-color: #198754; /* Vạch xanh lá đặc trưng */
                }

                .sidebar .nav-link i {
                    font-size: 1.2rem;
                }
        /* Vùng nội dung chính dịch sang phải để không bị che */
        .main-content {
            margin-left: 260px;
            padding: 30px;
            min-height: 100vh;
        }

        .user-profile {
            border-bottom: 1px solid #3d4145;
            padding-bottom: 20px;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="user-profile text-center px-3">
            <div class="bg-success text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 50px; height: 50px;">
                <i class="bi bi-person-badge fs-3"></i>
            </div>
            <h6 class="text-white mb-0 fw-bold">Bùi Quang Hào</h6>
            <small class="text-muted">MSSV: 2123110043</small>
        </div>

        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link" href="/Home">
                    <i class="bi bi-speedometer2"></i> Trang Chủ
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/Category">
                    <i class="bi bi-grid-1x2-fill"></i> Quản Lý Danh Mục
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/Post">
                    <i class="bi bi-newspaper"></i> Quản Lý Bài Viết
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/Product">
                    <i class="bi bi-box-seam-fill"></i> Quản Lý Sản Phẩm
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/Customer">
                    <i class="bi bi-people-fill"></i> Khách Hàng
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/Order">
                    <i class="bi bi-cart-check-fill"></i> Quản Lý Đơn Hàng
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/User">
                    <i class="bi bi-shield-lock-fill"></i> Tài Khoản Hệ Thống
                </a>
            </li>
        </ul>

        <div class="position-absolute bottom-0 start-0 w-100 p-3 text-center text-muted" style="font-size: 0.8rem; border-top: 1px solid #3d4145;">
            <span>&copy; 2026 - HaoCMS.Backend</span>
        </div>
    </div>

    <div class="main-content">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>