@model CMS.Data.Entities.Product
<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-warning text-dark"><h5><i class="bi bi-pencil-square"></i> CHỈNH SỬA SẢN PHẨM</h5></div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên sản phẩm:</label>
                    <input type="text" asp-for="Name" name="Name" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Giá bán (Price):</label>
                    <input type="number" asp-for="Price" name="Price" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Số lượng kho (StockQuantity):</label>
                    <input type="number" asp-for="StockQuantity" name="StockQuantity" class="form-control" required />
                </div>
                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                    <button type="submit" class="btn btn-warning fw-bold">Cập Nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>