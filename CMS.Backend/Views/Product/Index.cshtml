@model IEnumerable<CMS.Data.Entities.Product>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="fw-bold text-dark">QUẢN LÝ SẢN PHẨM</h3>
        <a href="/Product/Create" class="btn btn-success rounded-pill"><i class="bi bi-plus-lg"></i> Thêm Sản Phẩm</a>
    </div>

    <table class="table table-bordered table-hover bg-white shadow-sm text-center">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Tên Sản Phẩm</th>
                <th>Giá Bán</th>
                <th>Số Lượng Kho</th>
                <th>Hành Động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null)
            {
                foreach (var p in Model)
                {
                    <tr>
                        <td>@p.Id</td>
                        <td class="fw-bold text-primary">@p.Name</td>
                        <td>@p.Price.ToString("N0") đ</td>
                        <td>@p.StockQuantity</td>
                        <td>
                            <div class="d-flex justify-content-center gap-2">
                                <a href="/Product/Edit/@p.Id" class="btn btn-sm btn-warning rounded-pill px-3">Sửa</a>
                                <form action="/Product/Delete/@p.Id" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa sản phẩm này?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger rounded-pill px-3">Xóa</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>