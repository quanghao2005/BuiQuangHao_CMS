@model CMS.Data.Entities.User

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-warning text-dark">
            <h5 class="mb-0 fw-bold"><i class="bi bi-pencil-square"></i> CHỈNH SỬA NGƯỜI DÙNG</h5>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Id" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Tên đăng nhập:</label>
                    <input asp-for="Username" class="form-control" readonly />
                    <small class="text-muted">Tên đăng nhập không thể thay đổi.</small>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Mật khẩu mới:</label>
                    <input type="password" asp-for="PasswordHash" class="form-control" required />
                    <span asp-validation-for="PasswordHash" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Họ và tên:</label>
                    <input asp-for="FullName" class="form-control" required />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Vai trò:</label>
                    <select asp-for="Role" class="form-control">
                        <option value="Administrator">Quản trị viên</option>
                        <option value="Editor">Biên tập viên</option>
                    </select>
                </div>

                <div class="d-flex justify-content-end">
                    <a asp-action="Index" class="btn btn-secondary me-2">Quay lại</a>
                    <button type="submit" class="btn btn-warning text-dark fw-bold">Cập nhật thông tin</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}