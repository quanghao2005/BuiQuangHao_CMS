@model IEnumerable<CMS.Data.Entities.Order>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="fw-bold text-dark">QUẢN LÝ ĐƠN HÀNG</h3>
        <a href="/Order/Create" class="btn btn-success rounded-pill"><i class="bi bi-plus-lg"></i> Tạo Đơn Hàng</a>
    </div>

    <table class="table table-bordered table-hover bg-white shadow-sm text-center">
        <thead class="table-dark">
            <tr>
                <th>Mã Đơn Hàng (ID)</th>
                <th>Ngày Đặt Hàng</th>
                <th>Hành Động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null)
            {
                foreach (var o in Model)
                {
                    <tr>
                        <td><strong>#@o.Id</strong></td>
                        <td>@o.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <div class="d-flex justify-content-center gap-2">
                                <a href="/Order/Edit/@o.Id" class="btn btn-sm btn-warning rounded-pill px-3">Sửa</a>
                                <form action="/Order/Delete/@o.Id" method="post" onsubmit="return confirm('Bạn có chắc muốn hủy đơn hàng này?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger rounded-pill px-3">Xóa</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>