@model CMS.Data.Entities.Customer

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-success text-white py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-person-plus-fill"></i> THÊM KHÁCH HÀNG MỚI</h5>
        </div>

        <div class="card-body p-4 bg-white">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Id" value="0" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small fw-bold"></div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Họ và Tên khách hàng:</label>
                    <input type="text" asp-for="FullName" class="form-control" placeholder="Nhập đầy đủ họ tên..." required />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Địa chỉ Email:</label>
                    <input type="email" asp-for="Email" class="form-control" placeholder="viethao@example.com" required />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Số điện thoại:</label>
                    <input type="text" asp-for="Phone" class="form-control" placeholder="Nhập số điện thoại di động..." required />
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Mật khẩu đăng nhập:</label>
                    <input type="password" asp-for="Password" class="form-control" placeholder="Nhập mật khẩu tài khoản..." required />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <hr class="my-4">

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                        <i class="bi bi-arrow-left"></i> Quay lại danh sách
                    </a>
                    <button type="submit" class="btn btn-success rounded-pill px-4 fw-bold">
                        <i class="bi bi-check-circle-fill"></i> Lưu Khách Hàng
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}