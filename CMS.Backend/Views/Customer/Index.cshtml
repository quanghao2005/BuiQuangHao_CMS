@model IEnumerable<CMS.Data.Entities.Customer>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="fw-bold">QUẢN LÝ KHÁCH HÀNG</h3>
        <a href="/Customer/Create" class="btn btn-success rounded-pill"><i class="bi bi-plus-lg"></i> Thêm Khách Hàng</a>
    </div>

    <table class="table table-bordered table-hover bg-white shadow-sm text-center">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Họ Và Tên</th>
                <th>Email</th>
                <th>Số Điện Thoại</th>
                <th>Hành Động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null)
            {
                foreach (var c in Model)
                {
                    <tr>
                        <td>@c.Id</td>
                        <td class="fw-bold">@c.FullName</td>
                        <td>@c.Email</td>
                        <td>@c.Phone</td>
                        <td>
                            <div class="d-flex justify-content-center gap-2">
                                <a href="/Customer/Edit/@c.Id" class="btn btn-sm btn-warning rounded-pill px-3">Sửa</a>
                                <form action="/Customer/Delete/@c.Id" method="post" onsubmit="return confirm('Xóa khách hàng này?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger rounded-pill px-3">Xóa</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>