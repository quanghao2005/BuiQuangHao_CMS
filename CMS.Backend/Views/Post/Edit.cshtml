@model CMS.Data.Entities.Post

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-warning text-dark py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-pencil-square"></i> CHỈNH SỬA BÀI VIẾT</h5>
        </div>

        <div class="card-body p-4 bg-white">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label class="form-label fw-bold">Tiêu đề bài viết:</label>
                    <input type="text" asp-for="Title" class="form-control" required />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Hình ảnh minh họa bài viết:</label>
                    <input type="file" name="ImageFile" class="form-control" accept="image/*" />

                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div class="mt-2">
                            <span class="text-muted d-block small mb-1">Ảnh hiện tại:</span>
                            <img src="@Model.ImageUrl" class="img-thumbnail shadow-sm" style="max-height: 120px; object-fit: cover;" />
                        </div>
                    }
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Thuộc Chuyên Mục:</label>
                    <select asp-for="CategoryId" class="form-select" required>
                        <option value="">-- Chọn danh mục --</option>
                        @if (ViewBag.Categories != null)
                        {
                            // Ép kiểu tường minh từ dynamic về List Entity để tránh lỗi Expression Tree
                            var categories = (List<CMS.Data.Entities.Category>)ViewBag.Categories;

                            foreach (var cat in categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Nội dung bài viết:</label>
                    <textarea asp-for="Content" class="form-control" rows="8" required></textarea>
                    <span asp-validation-for="Content" class="text-danger small"></span>
                </div>

                <hr class="my-4">

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                    <button type="submit" class="btn btn-warning rounded-pill px-4 fw-bold text-dark">
                        <i class="bi bi-save-fill"></i> Cập Nhật Bài Viết
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>