@model IEnumerable<CMS.Data.Entities.Post>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">DANH SÁCH BÀI VIẾT</h2>
        <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-circle"></i> Thêm bài viết mới</a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <img src="@item.ImageUrl" class="card-img-top" alt="Ảnh bài viết" style="height: 200px; object-fit: cover;">

                    <div class="card-body">
                        <span class="badge bg-info text-dark mb-2">@(item.Category?.Name ?? "Chưa phân loại")</span>

                        <h5 class="card-title fw-bold">@item.Title</h5>

                        <p class="card-text text-muted small">
                            @(string.IsNullOrEmpty(item.Content) ? "Không có nội dung." :
                                                    (item.Content.Length > 80 ? item.Content.Substring(0, 80) + "..." : item.Content))
                    </p>

                        <p class="text-secondary small mt-auto">Ngày đăng: @item.CreatedDate.ToString("dd/MM/yyyy")</p>
                    </div>

                    <div class="card-footer bg-white border-0 pt-0 pb-3">
                        <div class="btn-group w-100">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">Xem chi tiết</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm">Sửa</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa?');">
                                <button type="submit" class="btn btn-outline-danger btn-sm">Xóa</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>